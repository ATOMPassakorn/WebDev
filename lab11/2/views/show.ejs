<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Product</title>
    <link rel="stylesheet" href="/css/card.css">
</head>

<body>
    <body>
        <%- include('nav.ejs') %>
        <h1>AUNTIE-AUN Restuarant</h1>
        <div class="container">
            <% data.forEach((item)=>{ %>
            <div class="card">
                <img src="<%=item.image_url%>" alt="">
                <h2><%=item.name%></h2>
                <p><%=item.description%></p>
                <p style="color: red;">Price: <%=item.price%> THB</p>
                <a href="/add-to-cart/<%= item.product_id %>"><button>Add to Cart</button></a>
            </div>
            <% }); %> 
        </div>
    </body>
</body>

</html>